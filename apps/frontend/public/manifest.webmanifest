{
  "name": "Item Scanner",
  "short_name": "Scanner",
  "description": "Scan items and assign storage locations faster.",
  "start_url": "/",
  "scope": "/",
  "display": "standalone",
  "background_color": "#eef2f5",
  "theme_color": "#10b981",
  "icons": [
    {
      "src": "/web-app-manifest-192x192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/web-app-manifest-512x512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    }
  ]
}
