NODE_ENV=production
PORT=4000

# When frontend and backend are on the same domain (e.g. EC2 reverse proxy),
# FRONTEND_URL and SHOPIFY_APP_URL should be the same domain.
# BACKEND_PUBLIC_URL can be omitted in that case — SHOPIFY_APP_URL is used as fallback.
FRONTEND_URL=https://your-domain.com
FRONTEND_URLS=https://your-domain.com

DATABASE_URL=file:/var/lib/item-scanner/data/app.db
JWT_SECRET=replace_with_a_long_random_secret_at_least_32_chars
ADMIN_KEY=replace_with_admin_creation_key

SHOPIFY_API_KEY=replace_me
SHOPIFY_API_SECRET=replace_me
# Must match exactly what is configured in Shopify Partner Dashboard → App setup → Scopes
SHOPIFY_SCOPES=read_orders,read_products,write_products,write_metafields
# Must match the App URL in Shopify Partner Dashboard → URLs → App URL
# Also used as the base for the OAuth redirect_uri (/api/shopify/oauth/callback)
SHOPIFY_APP_URL=https://your-domain.com
# Only set if backend runs on a different domain than the frontend.
# Leave unset when frontend and backend share the same domain.
# BACKEND_PUBLIC_URL=https://api.your-domain.com
SHOPIFY_API_VERSION=2025-10
SHOPIFY_METAFIELD_NAMESPACE=app
SHOPIFY_METAFIELD_KEY=item_location
