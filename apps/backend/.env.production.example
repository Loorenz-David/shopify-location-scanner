NODE_ENV=production
PORT=4000
FRONTEND_URL=https://your-frontend-domain.com
FRONTEND_URLS=https://staging-frontend.example.com
DATABASE_URL=file:/var/lib/item-scanner/data/app.db
JWT_SECRET=replace_with_a_long_random_secret_at_least_32_chars
ADMIN_KEY=replace_with_admin_creation_key

SHOPIFY_API_KEY=replace_me
SHOPIFY_API_SECRET=replace_me
SHOPIFY_SCOPES=read_products,write_products,write_metafields
SHOPIFY_APP_URL=https://your-frontend-domain.com
BACKEND_PUBLIC_URL=https://api.your-domain.com
SHOPIFY_API_VERSION=2025-10
SHOPIFY_METAFIELD_NAMESPACE=app
SHOPIFY_METAFIELD_KEY=item_location
