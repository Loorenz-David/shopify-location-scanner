generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  worker
}

enum ScanHistoryEventType {
  location_update
  unknown_position
  sold_terminal
}

enum ScanHistoryPriceTerminalType {
  unknown_position
  sold_terminal
  price_update
}

enum SalesChannel {
  webshop
  physical
  imported
  unknown
}

enum WebhookIntakeStatus {
  pending
  processing
  processed
  failed
}

model Shop {
  id            String        @id @default(cuid())
  shopDomain    String        @unique
  accessToken   String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  users         User[]
  scanHistories ScanHistory[]
  storeZones    StoreZone[]
  webhookDeliveries ShopifyWebhookDelivery[]
  webhookIntakeRecords WebhookIntakeRecord[]
}

model User {
  id            String        @id @default(cuid())
  username      String        @unique
  passwordHash  String
  role          UserRole      @default(worker)
  shopId        String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  shop          Shop?         @relation(fields: [shopId], references: [id], onDelete: SetNull)
  refreshTokens RefreshToken[]
  scanHistories ScanHistory[]

  @@index([shopId])
}

model RefreshToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  createdAt DateTime @default(now())
  revokedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model ScanHistory {
  id               String   @id @default(cuid())
  shopId           String
  userId           String?
  username         String
  productId        String
  itemCategory     String?
  itemSku          String?
  itemBarcode      String?
  itemImageUrl     String?
  itemType         String
  itemTitle        String
  itemHeight       Float?
  itemWidth        Float?
  itemDepth        Float?
  volume           Float?
  latestLocation   String?
  isSold           Boolean  @default(false)
  lastSoldChannel  SalesChannel?
  lastModifiedAt   DateTime @default(now())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  events           ScanHistoryEvent[]
  priceHistory     ScanHistoryPrice[]

  shop Shop  @relation(fields: [shopId], references: [id], onDelete: Restrict)
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([shopId, productId])
  @@index([shopId, lastModifiedAt])
  @@index([userId, lastModifiedAt])
  @@index([shopId, username])
  @@index([shopId, itemCategory])
  @@index([shopId, itemSku])
  @@index([shopId, itemBarcode])
  @@index([shopId, itemType])
  @@index([shopId, itemTitle])
  @@index([shopId, latestLocation])
  @@index([shopId, isSold, lastModifiedAt])
  @@index([shopId, lastSoldChannel, lastModifiedAt])
}

model ScanHistoryEvent {
  id            String   @id @default(cuid())
  scanHistoryId String
  username      String   @default("unknown")
  eventType     ScanHistoryEventType @default(location_update)
  orderId       String?
  orderGroupId  String?
  salesChannel  SalesChannel?
  location      String
  happenedAt    DateTime @default(now())
  createdAt     DateTime @default(now())

  scanHistory ScanHistory @relation(fields: [scanHistoryId], references: [id], onDelete: Cascade)

  @@index([scanHistoryId, happenedAt])
  @@index([scanHistoryId, eventType, happenedAt])
  @@index([scanHistoryId, orderGroupId, happenedAt])
  @@index([eventType, happenedAt])
  @@index([orderGroupId, happenedAt])
  @@index([username])
  @@index([location])
}

model ScanHistoryPrice {
  id            String   @id @default(cuid())
  scanHistoryId String
  price         String?
  terminalType  ScanHistoryPriceTerminalType?
  orderId       String?
  orderGroupId  String?
  happenedAt    DateTime @default(now())
  createdAt     DateTime @default(now())

  scanHistory ScanHistory @relation(fields: [scanHistoryId], references: [id], onDelete: Cascade)

  @@index([scanHistoryId, happenedAt])
  @@index([scanHistoryId, terminalType, happenedAt])
  @@index([scanHistoryId, orderGroupId, happenedAt])
  @@index([terminalType, happenedAt])
  @@index([orderGroupId, happenedAt])
}

model ShopifyWebhookDelivery {
  id         String   @id @default(cuid())
  shopId     String
  topic      String
  webhookId  String
  orderId    String?
  createdAt  DateTime @default(now())

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@unique([shopId, topic, webhookId])
  @@index([shopId, createdAt])
  @@index([topic, createdAt])
}

model WebhookIntakeRecord {
  id          String              @id @default(cuid())
  shopId      String
  shopDomain  String
  topic       String
  webhookId   String
  rawPayload  String
  dedupeKey   String              @unique
  status      WebhookIntakeStatus @default(pending)
  attempts    Int                 @default(0)
  processedAt DateTime?
  lastError   String?
  retryable   Boolean             @default(true)
  receivedAt  DateTime            @default(now())
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId, status])
  @@index([topic, status])
  @@index([status, createdAt])
}

model LocationStatsDaily {
  date                   DateTime
  location               String
  itemsSold              Int     @default(0) @map("items_sold")
  itemsReceived          Int     @default(0) @map("items_received")
  totalTimeToSellSeconds Float   @default(0) @map("total_time_to_sell_seconds")
  totalValuation         Float   @default(0) @map("total_valuation")

  @@id([date, location])
  @@map("location_stats_daily")
}

model LocationCategoryStatsDaily {
  date                   DateTime
  location               String
  itemCategory           String
  itemsSold              Int   @default(0) @map("items_sold")
  totalRevenue           Float @default(0) @map("total_revenue")
  totalTimeToSellSeconds Float @default(0) @map("total_time_to_sell_seconds")

  @@id([date, location, itemCategory])
  @@map("location_category_stats_daily")
}

model StoreZone {
  id        String   @id @default(cuid())
  shopId    String
  label     String
  type      String   @default("zone")
  xPct      Float    @map("x_pct")
  yPct      Float    @map("y_pct")
  widthPct  Float    @map("width_pct")
  heightPct Float    @map("height_pct")
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId, sortOrder])
  @@index([shopId, type])
}

model SalesChannelStatsDaily {
  date         DateTime
  shopId       String
  salesChannel SalesChannel
  itemsSold    Int   @default(0) @map("items_sold")
  totalRevenue Float @default(0) @map("total_revenue")

  @@id([date, shopId, salesChannel])
  @@index([shopId, date])
  @@map("sales_channel_stats_daily")
}
